{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "calendarExports": {
      "$secret": {
        ".read": true,
        ".write": "auth != null && root.child('users').child(auth.uid).child('calendarSecret').val() === $secret"
      }
    }
  }
}
